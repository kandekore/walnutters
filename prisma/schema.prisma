// Walnutterz data model — SQLite for dependency-light self-hosting.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite has no native enums; roles/statuses are validated in application code.

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  passwordHash     String
  name             String?
  role             String          @default("CUSTOMER") // CUSTOMER | ADMIN
  stripeCustomerId String?
  orders           Order[]
  reviews          Review[]
  paymentMethods   PaymentMethod[]
  createdAt        DateTime        @default(now())
}

model Product {
  id               String      @id @default(cuid())
  slug             String      @unique
  name             String
  sku              String?
  shortDescription String?
  description      String?
  regularPrice     Int // stored in pence
  salePrice        Int?
  currency         String      @default("GBP")
  stockStatus      String      @default("in_stock")
  imagePath        String?
  gallery          String      @default("[]") // JSON array of paths
  category         String?
  occasions        String      @default("[]") // JSON array for Gift Finder
  era              String? // decade for Football Time Tunnel, e.g. "1990s"
  featured         Boolean     @default(false)
  salesCount       Int         @default(0)
  active           Boolean     @default(true)
  orderItems       OrderItem[]
  reviews          Review[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  email           String
  customerName    String
  status          String      @default("PENDING") // PENDING | PAID | FULFILLED | CANCELLED
  paymentStatus   String      @default("unpaid") // unpaid | paid | mock_paid
  paymentIntentId String?
  subtotal        Int
  shipping        Int         @default(0)
  total           Int
  currency        String      @default("GBP")
  shippingAddress String? // JSON
  items           OrderItem[]
  createdAt       DateTime    @default(now())
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  unitPrice Int
  quantity  Int
  imagePath String?
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  authorName String
  rating     Int // out of 10
  text       String
  approved   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model PaymentMethod {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand                 String
  last4                 String
  expMonth              Int
  expYear               Int
  stripePaymentMethodId String?
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())
}

model CustomRequest {
  id              String   @id @default(cuid())
  name            String
  email           String
  favouritePlayer String?
  hairColour      String?
  shirtNumber     String?
  pose            String?
  personalMessage String?
  teamPhotoPath   String?
  kitPhotoPath    String?
  clubBadgePath   String?
  status          String   @default("NEW") // NEW | IN_PROGRESS | MOCKUP_SENT | COMPLETED
  adminNotes      String?
  createdAt       DateTime @default(now())
}

model GalleryItem {
  id           String   @id @default(cuid())
  customerName String
  imagePath    String
  category     String   @default("Football rooms")
  caption      String?
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model TimeTunnelPlayer {
  id          String  @id @default(cuid())
  decade      String
  name        String
  story       String
  productSlug String?
  sortOrder   Int     @default(0)
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String?
  body      String?
  imagePath String?
  videoUrl  String?
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String?
  body      String
  imagePath String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}
